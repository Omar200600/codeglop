<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>بوابة 3D Axis الذكية</title>
  <style>
    body {
      margin: 0; padding: 0;
      background: radial-gradient(circle, #1a1a1a 0%, #000 100%);
      overflow: hidden;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: gold;
    }

    #particles { position: fixed; top: 0; left: 0; z-index: -1; }

    .container {
      display: flex; justify-content: center; align-items: center;
      flex-wrap: wrap; height: 100vh; gap: 30px; padding: 20px;
    }

    .card {
      width: 220px; height: 280px;
      background: rgba(30, 30, 30, 0.8);
      border: 1px solid rgba(255, 215, 0, 0.3);
      border-radius: 20px;
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      cursor: pointer; position: relative;
    }

    .card:hover {
      transform: translateY(-15px) scale(1.05);
      box-shadow: 0 0 50px rgba(255, 215, 0, 0.4);
      border-color: gold;
    }

    .icon { font-size: 80px; margin-bottom: 15px; filter: drop-shadow(0 0 10px gold); }
    .label { font-size: 1.4em; font-weight: bold; text-shadow: 2px 2px 5px #000; }

    /* تأثير الهالة المضيئة خلف الكروت */
    .card::before {
      content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background: linear-gradient(45deg, transparent, rgba(255, 215, 0, 0.1), transparent);
      transition: 0.5s;
    }

    /* نافذة تسجيل الدخول */
    .modal {
      display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
      background: rgba(0, 0, 0, 0.95); padding: 30px; border: 2px solid gold;
      border-radius: 20px; z-index: 100; text-align: center; width: 300px;
    }
  </style>
</head>
<body>
  <canvas id="particles"></canvas>

  <div class="container">
    <div class="card" onclick="openModal('المدرسة')">
      <div class="icon">🎓</div>
      <div class="label">مدرسة موازية</div>
    </div>
    <div class="card" onclick="openModal('المول')">
      <div class="icon">🛍️</div>
      <div class="label">سوق 3D</div>
    </div>
    <div class="card" onclick="openModal('البرج')">
      <div class="icon">🏢</div>
      <div class="label">برج الأعمال</div>
    </div>
    <div class="card" onclick="openModal('مبنى الأمل')">
      <div class="icon">🕊️</div>
      <div class="label">مبنى الأمل</div>
    </div>
  </div>

  <div id="loginModal" class="modal">
    <h2 id="modalTitle"></h2>
    <p>اختر نوع الدخول:</p>
    <button onclick="enterWorld('visitor')" style="background: gold; padding: 10px; border: none; cursor: pointer; width: 100%; margin-bottom: 10px;">زائر</button>
    <button onclick="enterWorld('member')" style="background: transparent; border: 1px solid gold; color: gold; padding: 10px; cursor: pointer; width: 100%;">تسجيل دخول</button>
    <br><br>
    <button onclick="closeModal()" style="color: gray; background: none; border: none; cursor: pointer;">إغلاق</button>
  </div>

  <script>
    // كود الجزيئات الذهبية (نفس كود كوبيلوت مع تحسين الأداء)
    const canvas = document.getElementById('particles');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth; canvas.height = window.innerHeight;
    const pArray = [];
    class P {
      constructor() {
        this.x = Math.random()*canvas.width; this.y = Math.random()*canvas.height;
        this.s = Math.random()*2; this.vx = Math.random()*0.4-0.2; this.vy = Math.random()*0.4-0.2;
      }
      draw() { ctx.fillStyle='gold'; ctx.beginPath(); ctx.arc(this.x,this.y,this.s,0,Math.PI*2); ctx.fill(); }
      move() { this.x+=this.vx; this.y+=this.vy; if(this.x<0||this.x>canvas.width)this.vx*=-1; if(this.y<0||this.y>canvas.height)this.vy*=-1; }
    }
    for(let i=0;i<120;i++) pArray.push(new P());
    function anim() { ctx.clearRect(0,0,canvas.width,canvas.height); pArray.forEach(p=>{p.move();p.draw();}); requestAnimationFrame(anim); }
    anim();

    // وظائف التفاعل
    function openModal(name) {
      document.getElementById('modalTitle').innerText = name;
      document.getElementById('loginModal').style.display = 'block';
    }
    function closeModal() { document.getElementById('loginModal').style.display = 'none'; }
    function enterWorld(type) {
      alert("جاري توجيهك إلى عالم " + document.getElementById('modalTitle').innerText + " كـ " + type);
      // هنا سنضع روابط ملفات الـ HTML الخاصة بك في GitHub لاحقاً
    }
  </script>
</body>
</html>
